{
  "name": "@firstmate/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server exposing firstmate fleet state and steer controls",
  "bin": {
    "firstmate-mcp": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/src/index.js",
    "test": "npm run build && node --test dist/test/tools.test.js",
    "smoke": "npm run build && node dist/scripts/smoke.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.2",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/client": "2.0.0-beta.2",
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  }
}
